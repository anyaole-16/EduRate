<%- include('../partials/header', { title: 'Forgot Password', extraCss: 'auth.css' }) %>

<div class="auth-page">
  <div class="auth-bg-grid"></div>
  <div class="auth-bg-glow"></div>

  <div class="auth-card">
    <a href="/" class="auth-logo">
      <div class="auth-logo-header">
        <div class="auth-logo-mark">🔑</div>
        <h1>Edu<span>Rate</span></h1>
      </div>
    </a>

    <h2 class="auth-title">Reset Password</h2>
    <p class="auth-subtitle">Enter your email to receive a reset link</p>

    <% if (successMsg != null) { %>
      <div class="alert alert-success" style="margin-bottom:1rem">✓ <%= successMsg %></div>
    <% } %>
    <% if (errorMsg != null) { %>
      <div class="alert alert-danger" style="margin-bottom:1rem">⚠ <%= errorMsg %></div>
    <% } %>

    <form action="/auth/forgot-password" method="POST">
      <div class="form-group">
        <label class="form-label" for="email">Institutional Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-control"
          placeholder="you@university.edu"
          required
          autocomplete="email"
        >
      </div>
      <button type="submit" class="btn btn-primary btn-block">Send Reset Link</button>
    </form>

    <div class="auth-footer-link">
      <a href="/auth/login">← Back to Sign In</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
